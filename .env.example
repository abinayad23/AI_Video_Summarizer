# AI Video Summarizer - Environment Variables
# Copy this file to .env and fill in your actual API keys

# Google Gemini API Key (free tier available)
# Get key: https://makersuite.google.com/app/apikey
GOOGLE_GEMINI_API_KEY="your-gemini-api-key-here"

# OpenAI ChatGPT API Key (paid)
# Get key: https://platform.openai.com/api-keys
OPENAI_CHATGPT_API_KEY="your-openai-api-key-here"

# Groq API Key (free — powers Llama, Mistral, Gemma, DeepSeek, Qwen + Whisper)
# Get key: https://console.groq.com/keys
GROQ_API_KEY="your-groq-api-key-here"

# Note: At minimum, add GROQ_API_KEY — it gives you 6 free models + Whisper transcription
